<Window x:Class="DrawingUploader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DrawingUploader.ViewModels"
        xmlns:models="clr-namespace:DrawingUploader.Models"
        mc:Ignorable="d"
        Title="XREAL 图纸上传工具"
        Height="620" Width="780"
        MinHeight="480" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei, SimHei, Segoe UI, sans-serif"
        TextOptions.TextFormattingMode="Display"
        Background="#1A1D24"
        Foreground="#E8EAED">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Accent Colors -->
        <SolidColorBrush x:Key="AccentBrush" Color="#4A90D9"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#5BA0E9"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#34A853"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#EA4335"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#252A33"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#353B47"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9AA0A6"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8EAED"/>

        <!-- Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A404A"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2F3542"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EC5B4E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Progress Bar -->
        <Style x:Key="UploadProgressBar" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#2A2F3A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <Border x:Name="PART_Track" CornerRadius="4">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="4"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1D24"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bool to Visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Title Bar ═══ -->
        <Border Grid.Row="0" Background="Transparent" Padding="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📐" FontSize="24" Margin="0,0,8,0"/>
                    <TextBlock Text="XREAL 图纸上传工具" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="v1.0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Section: Device Connection -->
            <Border Grid.Row="0" Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🖥️ 设备连接" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <!-- Manual IP entry -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBox Text="{Binding ManualIp, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}" Width="130"
                                 ToolTip="输入 XREAL 设备 IP 地址"/>
                        <TextBlock Text=":" Margin="4,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{Binding ManualPort, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}" Width="60"
                                 ToolTip="端口号 (默认 8080)"/>
                        <Button Content="连接" Command="{Binding ConnectManualCommand}"
                                Style="{StaticResource PrimaryButton}" Padding="12,6"
                                Margin="6,0,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2" Padding="12,6"
                            Command="{Binding StartDiscoveryCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Content" Value="🔍 扫描设备"/>
                                <Setter Property="Command" Value="{Binding StartDiscoveryCommand}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDiscovering}" Value="True">
                                        <Setter Property="Content" Value="⏹ 停止扫描"/>
                                        <Setter Property="Command" Value="{Binding StopDiscoveryCommand}"/>
                                        <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Section: Device List Header -->
            <Border Grid.Row="1" Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1,1,1,0"
                    CornerRadius="8,8,0,0" Padding="14,8">
                <Grid>
                    <TextBlock Text="📋 发现设备" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Devices.Count, StringFormat='{}{0} 台在线'}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Device List -->
            <Border Grid.Row="2" Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1,0,1,1"
                    CornerRadius="0,0,8,8" Margin="0,0,0,10">
                <ListBox ItemsSource="{Binding Devices}"
                         SelectedItem="{Binding SelectedDevice}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         AllowDrop="False">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:DrawingDevice">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="🥽" FontSize="18"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"
                                               FontSize="14"/>
                                    <TextBlock Text="{Binding DisplayText}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="2"
                                        CornerRadius="4" Padding="8,2" Margin="0,0,4,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A3A1A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                    <Setter Property="Background" Value="#3A2020"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#34A853"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                        <Setter Property="Foreground" Value="#EA4335"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Section: File Selection & Upload -->
            <Border Grid.Row="3" Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    AllowDrop="True"
                    DragOver="OnDragOver"
                    Drop="OnDrop"
                    DragLeave="OnDragLeave">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📄" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding SelectedFileName, TargetNullValue='未选择文件'}"
                                   VerticalAlignment="Center" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="350"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="📂 选择文件" Command="{Binding SelectFileCommand}"
                                IsEnabled="{Binding CanSelectFile}"
                                Style="{StaticResource SecondaryButton}" Padding="12,6"
                                Margin="0,0,6,0"/>
                        <Button Content="⬆ 上传到设备"
                                Command="{Binding UploadCommand}"
                                IsEnabled="{Binding CanUpload}"
                                Style="{StaticResource PrimaryButton}" Padding="16,6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Upload Progress -->
            <Border Grid.Row="4" Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,8" Margin="0,0,0,8"
                    Visibility="{Binding IsUploading, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ProgressBar Grid.Column="0"
                                 Value="{Binding UploadProgress}"
                                 Style="{StaticResource UploadProgressBar}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,12,0"/>

                    <TextBlock Grid.Column="1"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Width="40" TextAlignment="Right">
                        <TextBlock.Text>
                            <Binding Path="UploadProgress" StringFormat="{}{0:P0}"/>
                        </TextBlock.Text>
                    </TextBlock>

                    <Button Grid.Column="2" Content="取消"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource DangerButton}" Padding="8,4"
                            Margin="8,0,0,0" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="5" Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="💡" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="2" Content="清除"
                            Command="{Binding ClearLogCommand}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand" FontSize="12"
                            Padding="8,2"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Bottom Tip ═══ -->
        <Border Grid.Row="2" Background="Transparent" Padding="0,8,0,0">
            <TextBlock Text="💡 提示：确保 XREAL 眼镜和电脑连接同一 WiFi 网络，点击「扫描设备」自动发现"
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
    </Grid>
</Window>
